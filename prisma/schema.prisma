generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  OWNER
  EMPLOYEE
  SALON
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  hashedPassword String
  role           Role      @default(EMPLOYEE)
  salonId        String?
  salon          Salon?    @relation(fields: [salonId], references: [id])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  stockMovements StockMovement[]

  @@map("users")
}

model Salon {
  id        String   @id @default(cuid())
  name      String
  ico       String?
  dic       String?
  contact   String?
  email     String?
  phone     String?
  city      String?
  language  String   @default("cs")
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]

  @@map("salons")
}

// ============================================================
// PRODUCT ENUMS
// ============================================================

enum ProductCategory {
  VIRGIN
  PREMIUM
  STANDARD
  SALE
}

enum ProcessingType {
  CLIP_IN
  TAPE_IN
  KERATIN
  WEFT
  MICRO_RING
  OTHER
}

// ============================================================
// PRODUCT -- template / type of hair. No stock, no purchase price.
// ============================================================

model Product {
  id             String          @id @default(cuid())
  name           String
  nameUk         String?
  nameRu         String?
  description    String?
  descriptionUk  String?
  descriptionRu  String?
  category       ProductCategory
  processingType ProcessingType
  photos         String[]
  archived       Boolean         @default(false)
  slug           String?         @unique
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  variants Variant[]

  @@index([category])
  @@index([processingType])
  @@index([archived])
  @@map("products")
}

// ============================================================
// VARIANT -- price variant = combination of length + color
// Prices in HALERE (integer, 1 CZK = 100 halere)
// ============================================================

model Variant {
  id                    String   @id @default(cuid())
  productId             String
  product               Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  lengthCm              Int
  color                 String
  wholesalePricePerGram Int
  retailPricePerGram    Int
  retailManualOverride  Boolean  @default(false)
  active                Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  deliveries     Delivery[]
  stockMovements StockMovement[]
  reservations   Reservation[]

  @@unique([productId, lengthCm, color])
  @@index([productId])
  @@map("variants")
}

// ============================================================
// PRICE_SETTINGS -- retail markup percentage per product category
// markupPercent is whole integer: 50 = 50%
// ============================================================

model PriceSettings {
  id            String          @id @default(cuid())
  category      ProductCategory @unique
  markupPercent Int
  updatedAt     DateTime        @updatedAt

  @@map("price_settings")
}

// ============================================================
// INVENTORY ENUMS
// ============================================================

enum Currency {
  CZK
  USD
  EUR
  UAH
}

enum StockMovementType {
  RECEIPT
  ISSUE
  RETURN
  COMPLAINT
  SAMPLE_OUT
  SAMPLE_RETURN
  ADJUSTMENT
}

// ============================================================
// SUPPLIER -- sensitive, OWNER only
// ============================================================

model Supplier {
  id          String     @id @default(cuid())
  name        String
  contactName String?
  email       String?
  phone       String?
  country     String?
  note        String?
  archived    Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  deliveries  Delivery[]

  @@index([archived])
  @@map("suppliers")
}

// ============================================================
// DELIVERY -- a physical batch/shipment that arrived at the warehouse
// Linked to a specific Variant (product + length + color)
// This is what FIFO operates on.
// ============================================================

model Delivery {
  id                      String    @id @default(cuid())
  variantId               String
  variant                 Variant   @relation(fields: [variantId], references: [id])

  supplierId              String
  supplier                Supplier  @relation(fields: [supplierId], references: [id])

  purchasePricePerGramRaw Int
  currency                Currency
  exchangeRate            Int

  purchasePricePerGramCZK Int

  initialGrams            Int
  initialPieces           Int
  pieceWeightGrams        Int?

  remainingGrams          Int
  remainingPieces         Int

  barcode                 String?   @unique
  batchCode               String?

  receivedInvoiceFile     String?

  stockedAt               DateTime  @default(now())
  note                    String?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  stockMovements          StockMovement[]

  @@index([variantId, stockedAt])
  @@index([supplierId])
  @@index([barcode])
  @@index([variantId, remainingGrams, stockedAt])
  @@map("deliveries")
}

// ============================================================
// STOCK_MOVEMENT -- every stock change is recorded here (audit trail)
// ============================================================

model StockMovement {
  id          String            @id @default(cuid())
  deliveryId  String
  delivery    Delivery          @relation(fields: [deliveryId], references: [id])
  variantId   String
  variant     Variant           @relation(fields: [variantId], references: [id])

  type        StockMovementType

  grams       Int
  pieces      Int

  userId      String
  user        User              @relation(fields: [userId], references: [id])
  note        String?

  saleItemId  String?
  returnId    String?
  complaintId String?

  createdAt   DateTime          @default(now())

  @@index([deliveryId])
  @@index([variantId])
  @@index([type])
  @@index([createdAt])
  @@index([userId])
  @@map("stock_movements")
}

// ============================================================
// RESERVATION -- holds stock for unconfirmed online orders (Step 6)
// ============================================================

model Reservation {
  id          String    @id @default(cuid())
  orderId     String
  variantId   String
  variant     Variant   @relation(fields: [variantId], references: [id])

  grams       Int
  pieces      Int
  active      Boolean   @default(true)

  createdAt   DateTime  @default(now())
  expiresAt   DateTime?

  @@index([variantId, active])
  @@index([orderId])
  @@map("reservations")
}
